{
  "name": "yugo-ops",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bash -lc \"ulimit -n 10000 || true; WATCHPACK_POLLING=true WATCHPACK_POLLING_INTERVAL=1000 next dev --hostname 127.0.0.1\"",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 next build",
    "unlock-next": "node -e \"const fs=require('fs');for(const p of ['.next/lock','.next/dev/lock']){try{fs.unlinkSync(p)}catch(e){if(e.code!=='ENOENT')throw e}}\"",
    "build:resume": "npm run unlock-next && npm run build",
    "lint": "eslint .",
    "start": "next start",
    "db:push": "npx supabase db push --include-all",
    "db:repair:drop-20260331-slot": "npx supabase migration repair --status reverted 20260331120000 --linked",
    "db:wipe-mock": "npx supabase@latest db query -f scripts/wipe-mock-operational-data.sql --linked --agent=no",
    "db:seed-rate-template": "npx supabase@latest db query -f scripts/seed-rate-card-template-org.sql --linked --agent=no",
    "db:wipe-mock-and-reseed-template": "npm run db:wipe-mock && npm run db:seed-rate-template",
    "migrate:rate-templates": "npx tsx scripts/run-migration.ts",
    "seed:messages": "npx tsx scripts/seed-messages.ts",
    "seed:crew": "npx tsx scripts/seed-crew-member.ts",
    "delete:sample-moves": "npx tsx scripts/delete-sample-test-moves.ts",
    "delete:sample-jobs": "npx tsx scripts/delete-sample-test-moves.ts",
    "generate-vapid": "node -e \"const w=require('web-push');const k=w.generateVAPIDKeys();console.log('NEXT_PUBLIC_VAPID_PUBLIC_KEY='+k.publicKey);console.log('VAPID_PRIVATE_KEY='+k.privateKey);\"",
    "generate-crew-secret": "node -e \"const c=require('crypto');const s=c.randomBytes(32).toString('base64url');console.log('CREW_SESSION_SECRET='+s);console.error('Add the line above to .env.local');\""
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@hubspot/api-client": "^13.4.0",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-query-devtools": "^5.99.2",
    "@tanstack/react-virtual": "^3.13.24",
    "@turf/turf": "^7.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.11.0",
    "mapbox-gl": "^3.18.1",
    "next": "16.1.6",
    "nextjs-toploader": "^3.9.17",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.73.1",
    "react-leaflet": "^5.0.0",
    "react-map-gl": "^8.1.0",
    "recharts": "^3.7.0",
    "resend": "^6.9.2",
    "sonner": "^2.0.7",
    "square": "^44.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jspdf": "^1.3.3",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "supabase": "^2.76.8",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
