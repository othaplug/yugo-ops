# ─── Supabase ───
# Use the anon / publishable key for NEXT_PUBLIC_SUPABASE_ANON_KEY — never the service_role key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional: if your host only has these names, next.config.ts maps them into NEXT_PUBLIC_*
# for the Edge proxy bundle at build time:
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App URLs ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_EMAIL_APP_URL=https://app.yugomoves.com

# ─── Auth & Security ───
SUPER_ADMIN_EMAIL=admin@yourdomain.com
TRACK_SIGNING_SECRET=generate-a-random-32-char-secret
CREW_SESSION_SECRET=generate-a-random-32-char-secret
CRON_SECRET=generate-a-random-32-char-secret
# Optional: set to 1 or true to enable verbose serverDebug() API logs in production (default: off).
# DEBUG_SERVER_LOGS=1

# ─── Square Payments ───
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_APP_ID=your-square-app-id
SQUARE_LOCATION_ID=your-square-location-id
SQUARE_ENVIRONMENT=sandbox
SQUARE_USE_SANDBOX=true
SQUARE_WEBHOOK_SIGNATURE_KEY=your-webhook-sig-key
NEXT_PUBLIC_SQUARE_APP_ID=your-square-app-id
NEXT_PUBLIC_SQUARE_LOCATION_ID=your-square-location-id
NEXT_PUBLIC_SQUARE_ENVIRONMENT=sandbox
NEXT_PUBLIC_SQUARE_USE_SANDBOX=true

# ─── Email (Resend) ───
RESEND_API_KEY=re_your-resend-api-key
ADMIN_NOTIFICATION_EMAIL=ops@yourdomain.com
COORDINATOR_EMAIL=coordinator@yourdomain.com
COORDINATOR_PHONE=+1234567890

# ─── SMS (OpenPhone) ───
OPENPHONE_API_KEY=your-openphone-api-key
OPENPHONE_PHONE_NUMBER_ID=your-phone-number-id

# ─── Mapping (Mapbox) ───
MAPBOX_TOKEN=pk.your-mapbox-token
MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token

# ─── Weather (OpenWeather) ───
OPENWEATHER_API_KEY=your-openweather-api-key

# ─── HubSpot CRM ───
HUBSPOT_ACCESS_TOKEN=your-hubspot-access-token
HUBSPOT_CLIENT_SECRET=your-hubspot-client-secret

# ─── Slack ───
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_ADMIN_CHANNEL=general
SLACK_CHANNEL_ID=C0123456789

# ─── Web Push (VAPID) ───
# Generate with: npm run generate-vapid
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ─── reCAPTCHA ───
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-site-key
RECAPTCHA_SECRET_KEY=your-secret-key

# ─── QuickBooks (optional) ───
# QUICKBOOKS_CLIENT_ID=your-client-id
# QUICKBOOKS_CLIENT_SECRET=your-client-secret

# ─── Zapier (optional) ───
# ZAPIER_WEBHOOK_SECRET=your-zapier-secret

# ─── Google Review ───
GOOGLE_REVIEW_URL=https://g.page/r/your-review-link
NEXT_PUBLIC_REVIEW_URL=https://g.page/r/your-review-link

# ─── Branding / Contact ───
NEXT_PUBLIC_YUGO_PHONE=+1234567890
NEXT_PUBLIC_YUGO_EMAIL=hello@yugomoves.com

# ─── Timezone ───
APP_TIMEZONE=America/Toronto
BUSINESS_TIMEZONE=America/Toronto
NEXT_PUBLIC_APP_TIMEZONE=America/Toronto
CREW_DASHBOARD_TIMEZONE=America/Toronto
# Set to 0 to hide the dashboard sample move in development. Set to 1 in staging to show it.
# CREW_DASHBOARD_SAMPLE_MOVE=0
